# Normalize text files across macOS and Windows checkouts.
* text=auto

# Keep source files as LF in repo and working tree.
*.c text eol=lf
*.cc text eol=lf
*.cpp text eol=lf
*.h text eol=lf
*.hpp text eol=lf
*.py text eol=lf
*.json text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf

# Windows-native scripts.
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf
